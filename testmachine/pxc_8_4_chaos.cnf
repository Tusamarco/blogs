[client]
port = 3306
socket = /opt/mysql_instances/test-tpcc-pxc-84/mysql.sock
ssl-mode = disabled
[mysqldump]
quick
quote-names
max_allowed_packet  = 48M
[mysql]
prompt=(\\u@\\h) [\\d]>\\
[isamchk]
key_buffer    = 16M
[mysqld_safe]
log-error = /opt/mysql_instances/test-tpcc-pxc-84/mysql-3306.err
open-files-limit= 65536
[mysqld]
basedir                                                     =/opt/mysql_templates/PXC-84/
datadir = /opt/mysql_instances/test-tpcc-pxc-84/data
lc_messages_dir                                             =/opt/mysql_templates/PXC-84/share/
local_infile                                                = 1
log-error = /opt/mysql_instances/test-tpcc-pxc-84/mysql-3306.err
pid-file = /opt/mysql_instances/test-tpcc-pxc-84/mysqld.pid
plugin-dir                                                  =/opt/mysql_templates/PXC-84/lib/plugin/
port = 3306
secure-file-priv                                            =""
server-id = 3306
socket = /opt/mysql_instances/test-tpcc-pxc-84/mysql.sock
tmpdir = /opt/mysql_instances/test-tpcc-pxc-84/temp
user                                                        =mysql
default_time_zone='+01:00'
max-connections                                             =2500
table_definition_cache                                     = 4096
tablespace-definition-cache                                 =256
table_open_cache                                           = 4096
table-open-cache-instances                                  =4
thread_cache_size                                          = 1024
thread_stack                                               = 256K
thread_handling                                            = one-thread-per-connection
binlog_cache_size	= 1M
binlog_stmt_cache_size = 1M
join_buffer_size = 32M
max_heap_table_size = 16M
read_buffer_size = 1M
read_rnd_buffer_size = 16M
sort_buffer_size = 1M
tmp_table_size = 16M
innodb_adaptive_hash_index                                  =off
innodb_autoinc_lock_mode                                    =2
innodb_buffer_pool_in_core_file                             =OFF
innodb_buffer_pool_instances                                = 40 #innodb_buffer_pool_size / innodb_buffer_pool_chunk_size (134217728)) / 2)
innodb_buffer_pool_size                                     =10G
innodb_change_buffering                                     =none
innodb_data_file_path                                       =ibdata1:100M:autoextend
innodb_data_home_dir                                        = /opt/mysql_instances/test-tpcc-pxc-84/data
innodb_doublewrite_files                                    =2 #By default, two doublewrite files are created for each buffer pool instance.
innodb_doublewrite_pages                                    =128
innodb_flush_method                                         =O_DIRECT    #O_DIRECT_NO_FSYNC #O_DIRECT
innodb_use_fdatasync                                        =1
innodb_io_capacity                                          =10000
innodb_io_capacity_max                                      = 20000 #(innodb_io_capacity * 2)
innodb_log_buffer_size                                      =64M
innodb_redo_log_capacity                                    =2G
innodb_log_group_home_dir                                   = /opt/mysql_instances/test-tpcc-pxc-84/logs
innodb_monitor_enable					                    =all
innodb_numa_interleave                                      =ON
innodb_page_cleaners                                        = 40 #number of BP
innodb_parallel_read_threads                                = 8  #logical processors  /8 
innodb_purge_threads                                        = 4 # if more than 16 core then 4 
innodb_read_io_threads                                      = 32 #logical processors / 2 (min 4)
innodb_redo_log_capacity                                    = 3355443200
innodb_sync_array_size                                      = 12
innodb_write_io_threads                                     = 32
pxc_encrypt_cluster_traffic                                 = OFF
pxc_maint_mode                                              = DISABLED
pxc_maint_transition_period                                 = 10
pxc_strict_mode                                             = ENFORCING #PERMISSIVE DISABLED
wsrep-OSU-method                                            = TOI
wsrep-RSU-commit-timeout                                    = 5000
wsrep-SR-store                                              = table
wsrep-auto-increment-control                                = TRUE
wsrep-causal-reads                                          = FALSE
wsrep-certification-rules                                   = strict
wsrep-certify-nonPK                                         = TRUE
wsrep-cluster-address                                       = gcomm://10.30.50.201,10.30.50.203,10.30.50.204
wsrep-cluster-name                                          = lab84DC1
wsrep-dbug-option                                           = 0 #SERVER,TRANSACTION,STREAMING,CLIENT
wsrep-debug                                                 = 0
wsrep-desync                                                = FALSE
wsrep-dirty-reads                                           = FALSE
wsrep-ignore-apply-errors                                   = 7
wsrep-load-data-splitting                                   = TRUE
wsrep-log-conflicts                                         = TRUE
wsrep-max-ws-rows                                           = 0
wsrep-max-ws-size                                           = 2147483647
wsrep_min_log_verbosity                                     = 3
wsrep-node-address                                          = 10.30.50.204:4567
wsrep-node-incoming-address                                 = 10.30.50.204:3306
wsrep-node-name                                             = node3
wsrep-on                                                    = TRUE
wsrep-provider                                              = /opt/mysql_templates/PXC-84/lib/libgalera_smm.so
wsrep-provider-options                                      = "pc.weight=1;gmcast.listen_addr=tcp://10.30.50.204:4567;gmcast.segment=2;socket.ssl_compression=no;gcache.keep_pages_size=4;gcache.page_size=32M;gcache.size=10024M;evs.send_window=1024;evs.user_send_window=1024;evs.use_aggregate = true;gcs.fc_factor = 0.9;gcs.fc_limit = 64;gcs.max_packet_size = 131072;gcs.fc_debug = 0;evs.inactive_check_period = PT1S;evs.inactive_timeout = PT20S;evs.suspect_timeout = PT5S;evs.stats_report_period = PT1M;"
wsrep-recover                                               = 0
wsrep-reject-queries                                        = NONE
wsrep-replicate-myisam                                      = FALSE
wsrep-restart-slave                                         = FALSE
wsrep-retry-autocommit                                      = 3
wsrep-slave-FK-checks                                       = FALSE
wsrep-slave-UK-checks                                       = FALSE
wsrep-slave-threads                                         = 4
wsrep-sst-donor-rejects-queries                             = FALSE
wsrep-sst-method                                            = clone #xtrabackup-v2  #clone
wsrep_sst_allowed_methods                                   = xtrabackup-v2,clone
wsrep-sst-receive-address                                   = AUTO
wsrep-sync-wait                                             = 0 #avod stale read with 7
wsrep-trx-fragment-size                                     = 0
wsrep-trx-fragment-unit                                     = bytes
[sst]
netcat_port=4442
wsrep-debug=true
clone_instance_port=4444
log_bin = /opt/mysql_instances/test-tpcc-pxc-84/logs/binlog
binlog_expire_logs_seconds=10
long_query_time=240
slow-query-log = 0
slow-query-log-file = /opt/mysql_instances/test-tpcc-pxc-84/logs/slow.log
general-log-file = /opt/mysql_instances/test-tpcc-pxc-84/logs/general.log
general-log 
