[client]
port = 3306
socket = /opt/mysql_instances/test-tpcc-ps-84/mysql.sock
ssl-ca = /opt/mysql_templates/PS-84/cert/ca.pem
ssl-cert = /opt/mysql_templates/PS-84/cert/client-cert.pem
ssl-key = /opt/mysql_templates/PS-84/cert/client-key.pem
ssl-mode = disabled
[mysqldump]
quick
quote-names
max_allowed_packet  = 48M
[mysql]
prompt=(\\u@\\h) [\\d]>\\
[isamchk]
key_buffer    = 16M
[mysqld_safe]
log-error = /opt/mysql_instances/test-tpcc-ps-84/mysql-3306.err
open-files-limit= 65536
[mysqld]
basedir                                                     =/opt/mysql_templates/PS-84/
datadir = /opt/mysql_instances/test-tpcc-ps-84/data
lc_messages_dir                                             =/opt/mysql_templates/PS-84/share/
local_infile                                                = 1
log-error = /opt/mysql_instances/test-tpcc-ps-84/mysql-3306.err
pid-file = /opt/mysql_instances/test-tpcc-ps-84/mysqld.pid
plugin-dir                                                  =/opt/mysql_templates/PS-84/lib/plugin/
port = 3306
secure-file-priv                                            =""
server-id = 33063
socket = /opt/mysql_instances/test-tpcc-ps-84/mysql.sock
tmpdir = /opt/mysql_instances/test-tpcc-ps-84/temp
user                                                        =mysql
default_time_zone='+01:00'
max-connections                                             =2500
table_definition_cache                                     = 4096
tablespace-definition-cache                                 =256
table_open_cache                                           = 4096
table-open-cache-instances                                  =4
thread_cache_size                                          = 1024
thread_stack                                               = 256K
thread_handling                                            = one-thread-per-connection
binlog_cache_size	= 1M
binlog_stmt_cache_size = 1M
join_buffer_size = 32M
max_heap_table_size = 16M
read_buffer_size = 1M
read_rnd_buffer_size = 16M
sort_buffer_size = 1M
tmp_table_size = 16M
innodb_adaptive_hash_index                                  =off
innodb_autoinc_lock_mode                                    =2
innodb_buffer_pool_in_core_file                             =OFF
innodb_buffer_pool_instances                                = 40 #innodb_buffer_pool_size / innodb_buffer_pool_chunk_size (134217728)) / 2)
innodb_buffer_pool_size                                     =10G
innodb_change_buffering                                     =none
innodb_data_file_path                                       =ibdata1:100M:autoextend
innodb_data_home_dir                                        = /opt/mysql_instances/test-tpcc-ps-84/data
innodb_doublewrite_files                                    =2 #By default, two doublewrite files are created for each buffer pool instance.
innodb_doublewrite_pages                                    =128
innodb_flush_method                                         =O_DIRECT    #O_DIRECT_NO_FSYNC #O_DIRECT
innodb_use_fdatasync                                        =1
innodb_io_capacity                                          =10000
innodb_io_capacity_max                                      = 20000 #(innodb_io_capacity * 2)
innodb_log_buffer_size                                      =64M
innodb_redo_log_capacity                                    =2G
innodb_log_group_home_dir                                   = /opt/mysql_instances/test-tpcc-ps-84/logs
innodb_monitor_enable					                    =all
innodb_numa_interleave                                      =ON
innodb_page_cleaners                                        = 40 #number of BP
innodb_parallel_read_threads                                = 8  #logical processors  /8 
innodb_purge_threads                                        = 4 
innodb_read_io_threads                                      = 32 
innodb_redo_log_capacity                                    = 3355443200
innodb_sync_array_size                                      = 12
innodb_write_io_threads                                     = 32
plugin_load_add                                     ='mysql_clone.so'
plugin_load_add                                     ='group_replication.so'
group_replication_group_name                        ="DC1aaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
group_replication_start_on_boot                     =off
group_replication_local_address                     = "10.30.50.204:33061"
group_replication_group_seeds                       = "10.30.50.201:33061,10.30.50.203:33061,10.30.50.204:33061"
group_replication_bootstrap_group                   = off
group_replication_autorejoin_tries = 7
group_replication_communication_max_message_size = 5097152
group_replication_flow_control_period = 1
group_replication_member_expel_timeout = 12
group_replication_message_cache_size = 3432511670
group_replication_paxos_single_leader = ON
group_replication_poll_spin_loops = 20000
group_replication_consistency=EVENTUAL
log_bin = /opt/mysql_instances/test-tpcc-ps-84/logs/binlog
binlog_expire_logs_seconds=10
enforce-gtid-consistency                                    =TRUE
explicit-defaults-for-timestamp                             =TRUE
gtid-mode                                                   =ON
long_query_time=240
slow-query-log = 0
slow-query-log-file = /opt/mysql_instances/test-tpcc-ps-84/logs/slow.log
general-log-file = /opt/mysql_instances/test-tpcc-ps-84/logs/general.log
general-log   